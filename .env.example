# データベース接続（docker-compose.ymlのPOSTGRES_PASSWORDと合わせる）
DATABASE_URL=postgresql://readlater:your-db-password@postgres:5432/readlater

# JWT署名シークレット（必須・ランダムな文字列を設定）
# 生成例: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# 自動巡回の認証シークレット（必須・docker-compose.ymlのfeed-cronと合わせる）
CRON_SECRET=change-me-to-another-random-string

# Claude APIキー（任意 — AIダイジェスト・リサーチを使う場合のみ）
# https://console.anthropic.com で取得
# ANTHROPIC_API_KEY=sk-ant-...
